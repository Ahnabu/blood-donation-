# =============================================================
# BLOOD DONATION PLATFORM — Environment Variables Template
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# =============================================================

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/blooddonation?retryWrites=true&w=majority

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string-32-chars-min

# Cloudinary (for NID photo uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Resend (for email notifications)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# Mapbox (admin geospatial map)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyxxxxxxxxxxxxxxxxxxxxx

# Stadia Maps (dark map tiles for location picker — free tier at stadiamaps.com)
NEXT_PUBLIC_STADIA_API_KEY=your-stadia-api-key-here

# Optional: Google OAuth (if you enable Google sign-in)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
